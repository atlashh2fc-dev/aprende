# ─────────────────────────────────────────────────────────────
# Aprende LMS · Variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Solo servidor (Project Settings → API → service_role). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# URL pública del sitio (para OAuth redirect y emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Marca (white-label). Opcional: si se omiten, se usan los valores
# por defecto de lib/brand.ts. Permiten rebrandear por entorno sin
# tocar código (útil para múltiples clientes / despliegues).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME=Aprende
NEXT_PUBLIC_BRAND_TAGLINE=El centro de aprendizaje para tu comunidad
# NEXT_PUBLIC_BRAND_LOGO_URL=/logo.svg
# NEXT_PUBLIC_BRAND_COLOR_PRIMARY=#d4a843
# NEXT_PUBLIC_BRAND_COLOR_ACCENT=#6b5ce7
# NEXT_PUBLIC_BRAND_MODE=dark
